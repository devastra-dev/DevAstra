{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["dom", "dom.iterable", "esnext"],

    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,

    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",

    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",

    /* 🔥 PATH ALIAS (IMPORTANT) */
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },

    /* ⚡ PERFORMANCE */
    "incremental": true
  },

  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx"
  ],

  "exclude": ["node_modules"]
}